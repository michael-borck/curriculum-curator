{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "outDir": "./out"
  },
  "include": [
    "src/**/*.ts",
    "electron.vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "out",
    "dist"
  ]
}

# E2E Test Environment
# Copy this to backend/.env before running the test backend

SECRET_KEY=e2e-test-secret-key-not-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Dedicated test database (separate from dev/prod)
DATABASE_URL=sqlite:///./data/test_e2e.db

# Dev email — prints verification codes to console instead of sending
EMAIL_PROVIDER=dev
EMAIL_DEV_MODE=true

# Disable rate limiting for test speed
TESTING=true
DISABLE_RATE_LIMIT=true

# Allow any email domain to register
EMAIL_WHITELIST=[]

DEBUG=true

# Use Anthropic Haiku for AI tests (cheap + fast)
# ANTHROPIC_API_KEY is expected in the shell environment
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-haiku-4-5-20251001

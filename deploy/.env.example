# Curriculum Curator — VPS Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ── Security ──────────────────────────────────────────────
# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Database ──────────────────────────────────────────────
# Absolute path inside container — do NOT change unless you also update volume mounts
DATABASE_URL=sqlite:////app/backend/data/curriculum_curator.db

# ── Local Mode ────────────────────────────────────────────
# Set to true for single-user/privacy mode (no login required)
LOCAL_MODE=false

# ── LLM API Keys (optional — users can also configure in-app) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Ollama (when using --profile local-ai) ────────────────
# Set to http://ollama:11434 when running ollama in the compose stack
OLLAMA_BASE_URL=http://localhost:11434

# ── Feature Flags ─────────────────────────────────────────
ENABLE_AI_FEATURES=true
ENABLE_FILE_UPLOAD=true
DEBUG=false

# ── Email (optional — enables password reset & invitations) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Curriculum Curator
SMTP_TLS=true
